<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Phobri.Desktop.ViewModels"
        xmlns:models="using:Phobri.Desktop.Models"
        xmlns:infra="using:Phobri.Desktop.Infrastructure"
        xmlns:services="using:Phobri.Desktop.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Phobri.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Phobri — Phone Bridge"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <infra:ByteArrayToBitmapConverter x:Key="ByteToBitmapConverter" />
    </Window.Resources>

    <DockPanel>
        <!-- Status Bar (Bottom) -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" />
                <TextBlock VerticalAlignment="Center" FontSize="12">
                    <Run Text="Phone: " />
                    <Run Text="{Binding IsConnected}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Toolbar (Top) -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: App title + connection indicator -->
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="📱 Phobri" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ConnectionStatusText}" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Center: All action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Vault -->
                    <Button Command="{Binding UnlockVaultCommand}"
                            IsVisible="{Binding ShowUnlockButton}"
                            ToolTip.Tip="Unlock the encrypted vault">
                        🔓 Unlock
                    </Button>
                    <Button Command="{Binding LockVaultCommand}"
                            IsVisible="{Binding ShowLockButton}"
                            ToolTip.Tip="Lock the encrypted vault">
                        🔒 Lock
                    </Button>

                    <!-- Server -->
                    <Button Command="{Binding StartServerCommand}"
                            IsVisible="{Binding ShowStartButton}"
                            ToolTip.Tip="Start the sync server">
                        ▶ Start
                    </Button>
                    <Button Command="{Binding StopServerCommand}"
                            IsVisible="{Binding ShowStopButton}"
                            ToolTip.Tip="Stop the sync server">
                        ⏹ Stop
                    </Button>

                    <Separator Width="1" Height="18" Margin="6,0" />

                    <!-- Navigation -->
                    <Button Command="{Binding NavigateToMessagesCommand}"
                            ToolTip.Tip="View SMS messages">
                        📨 Messages
                    </Button>
                    <Button Command="{Binding NavigateToCallsCommand}"
                            ToolTip.Tip="View call log">
                        📞 Calls
                    </Button>

                    <Separator Width="1" Height="18" Margin="6,0" />

                    <!-- Actions -->
                    <Button Command="{Binding WakePhoneCommand}"
                            CommandParameter="{Binding PhoneIp}"
                            IsEnabled="{Binding IsServerRunning}"
                            ToolTip.Tip="Wake phone via UDP or FCM">
                        📡 Wake Phone
                    </Button>
                    <Button Command="{Binding NavigateToSettingsCommand}"
                            ToolTip.Tip="Settings, pairing, and configuration">
                        ⚙ Settings
                    </Button>
                </StackPanel>

                <!-- Right: Server status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ServerStatusText}" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: TabControl -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Messages Tab -->
            <TabItem Header="📨 Messages">
                <Grid Margin="8" RowDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Messages" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="(newest first)" FontSize="11"
                                   VerticalAlignment="Center" Opacity="0.5" />
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding SmsViewModel.Messages}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:SmsMessage">
                                <Border Padding="8,4" Margin="0,1"
                                        BorderBrush="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="13" />
                                            <TextBlock Text="{Binding Type}" FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" FontSize="11" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:g}">
                                                    <Binding Path="DateTime" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                                   Text="{Binding Body}"
                                                   TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Calls Tab -->
            <TabItem Header="📞 Calls">
                <Grid Margin="8" RowDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Call Log" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="(newest first)" FontSize="11"
                                   VerticalAlignment="Center" Opacity="0.5" />
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding CallLogViewModel.Calls}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:CallLogEntry">
                                <Border Padding="8,6" Margin="0,1"
                                        BorderBrush="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0" Text="📞" FontSize="16"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="13" />
                                            <TextBlock Text="{Binding Number}" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Type}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="8,0" />
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:g}">
                                                        <Binding Path="DateTime" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DurationFormatted}" FontSize="11"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Log Tab -->
            <TabItem Header="📋 Log">
                <Grid Margin="8" RowDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Event Log" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="(newest first)" FontSize="11"
                                   VerticalAlignment="Center" Opacity="0.5" />
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LogViewModel.Entries}"
                             FontFamily="Courier New" FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="services:LogEntry">
                                <Border Padding="4,2" Margin="0,1">
                                    <Grid ColumnDefinitions="55,Auto,*" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Column="0" Grid.Row="0"
                                                   Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                   Foreground="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                                                   FontSize="10" />
                                        <Border Grid.Column="1" Grid.Row="0"
                                                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                                CornerRadius="3" Padding="4,1" Margin="4,0">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="9" FontWeight="Bold" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Grid.Row="0"
                                                   Text="{Binding Message}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Grid.Row="1"
                                                   Text="{Binding Detail}"
                                                   Foreground="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                                                   FontSize="9"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding Detail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="⚙ Settings">
                <ScrollViewer Margin="16">
                    <StackPanel Spacing="12" MaxWidth="500">
                        <TextBlock Text="Settings &amp; Pairing" FontSize="20" FontWeight="Bold" />

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Server Status" FontWeight="Bold" FontSize="14" />
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Running: {0}">
                                            <Binding Path="IsServerRunning" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Phone Connected: {0}">
                                            <Binding Path="IsConnected" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Device Pairing" FontWeight="Bold" FontSize="14" />

                                <!-- Generate Token + Show QR -->
                                <Button Command="{Binding PairingViewModel.GeneratePairTokenCommand}"
                                        Content="Generate Pairing Token"
                                        IsEnabled="{Binding IsServerRunning}" />

                                <!-- QR Code Image (auto-hidden by Avalonia when Source is null) -->
                                <Image Source="{Binding PairingViewModel.QrCodePng,
                                    Converter={StaticResource ByteToBitmapConverter}}"
                                       Width="240" Height="240"
                                       HorizontalAlignment="Center" />

                                <!-- Local address selector -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Local Address:" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding PairingViewModel.LocalAddresses}"
                                              SelectedItem="{Binding PairingViewModel.SelectedLocalAddress}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <!-- QR Code URI (click to copy) -->
                                <TextBox Text="{Binding PairingViewModel.QrCodeUri}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontSize="10"
                                         FontFamily="Courier New" />

                                <!-- Token text (as fallback) -->
                                <TextBlock Text="{Binding PairingViewModel.PairingToken}"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           FontFamily="Courier New" />

                                <TextBlock Text="{Binding PairingViewModel.Fingerprint}"
                                           FontSize="11" FontFamily="Courier New" />

                                <Button Command="{Binding PairingViewModel.UnpairCommand}"
                                        Content="Unpair Device"
                                        IsEnabled="{Binding PairingViewModel.IsPaired}" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🔒 Vault" FontWeight="Bold" FontSize="14" />
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Configured: {0}">
                                            <Binding Path="IsVaultConfigured" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Unlocked: {0}">
                                            <Binding Path="IsVaultUnlocked" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <!-- Lock/Unlock moved to main toolbar -->
                                <TextBlock Text="Use the 🔒 Lock / 🔓 Unlock buttons in the toolbar above."
                                           FontSize="11" Opacity="0.7" />
                                <TextBlock Text="The vault encrypts all messages, call logs, and pairing keys on disk. Locking clears all keys from memory."
                                           FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="External Access" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="{Binding ExternalIp}" />
                                <TextBlock Text="For off-LAN access, forward ports 8765-8766 to this machine."
                                           FontSize="11" />
                                <Button Command="{Binding RefreshExternalIpCommand}" Content="Refresh IP" />
                            </StackPanel>
                        </Border>

                        <!-- FCM Push Configuration -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="☁ FCM Push Configuration" FontWeight="Bold" FontSize="14" />

                                <TextBlock Text="FCM lets the desktop wake your phone and tell it the server address — useful when the server IP changes or the phone sync stops."
                                           FontSize="11" Opacity="0.7" TextWrapping="Wrap" />

                                <!-- Status indicator -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Status:" FontSize="11" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding PairingViewModel.FcmStatusText}"
                                               FontSize="11" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </StackPanel>

                                <!-- Service account key path -->
                                <TextBlock Text="Service Account Key Path:" FontSize="11" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Text="{Binding PairingViewModel.FcmServiceAccountPath}"
                                             PlaceholderText="~/.phobri/fcm-service-account.json"
                                             FontSize="11" FontFamily="Courier New"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Content="📁 Browse"
                                            VerticalAlignment="Center"
                                            Click="BrowseFcmKey_Click" />
                                </Grid>

                                <Button Command="{Binding PairingViewModel.ConfigureFcmCommand}"
                                        Content="Configure FCM"
                                        HorizontalAlignment="Left" />

                                <TextBlock Text="⚠ This is NOT the same file as google-services.json. Get it from: Firebase Console → ⚙ Project Settings → Service Accounts → Generate New Private Key."
                                           FontSize="10" Opacity="0.5" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Wake Phone -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="📲 Wake Phone" FontWeight="Bold" FontSize="14" />

                                <TextBlock Text="If the phone is disconnected, click Wake to tell it to connect. Tries UDP (LAN) first, then FCM push (internet)."
                                           FontSize="11" Opacity="0.7" TextWrapping="Wrap" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Text="{Binding PhoneIp}"
                                             PlaceholderText="Phone IP (e.g. 192.168.1.10)"
                                             FontSize="11"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Command="{Binding WakePhoneCommand}"
                                            CommandParameter="{Binding PhoneIp}"
                                            Content="📡 Wake Phone" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
