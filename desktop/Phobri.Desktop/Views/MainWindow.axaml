<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Phobri.Desktop.ViewModels"
        xmlns:models="using:Phobri.Desktop.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Phobri.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Phobri — Phone Bridge"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Status Bar (Bottom) -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" />
                <TextBlock VerticalAlignment="Center" FontSize="12">
                    <Run Text="Phone: " />
                    <Run Text="{Binding IsConnected}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Toolbar (Top) -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="📱 Phobri" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,12,0" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Content="📨 Messages"
                            Command="{Binding SmsViewModel.LoadConversationsCommand}" />
                    <Button Content="📞 Calls"
                            Command="{Binding CallLogViewModel.LoadCallLogCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding StartServerCommand}">
                        ▶ Start Server
                    </Button>
                    <Button Command="{Binding StopServerCommand}">
                        ⏹ Stop
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: TabControl -->
        <TabControl>
            <!-- Messages Tab -->
            <TabItem Header="📨 Messages">
                <Grid ColumnDefinitions="280,*">
                    <!-- Conversation List -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                            BorderThickness="0,0,1,0">
                        <ListBox ItemsSource="{Binding SmsViewModel.Conversations}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ConversationGroup">
                                    <Border Padding="8,6">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="Bold" FontSize="13" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding LastMessagePreview}"
                                                       FontSize="11" />
                                            <TextBlock Grid.Column="1" Grid.RowSpan="2"
                                                       FontSize="10" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:g}">
                                                        <Binding Path="LastMessageDate" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Message Detail -->
                    <Border Grid.Column="1" Padding="8">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <TextBlock Text="Messages" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" />
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding SmsViewModel.Messages}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:SmsMessage">
                                        <Border Padding="8,4" Margin="0,2" CornerRadius="6">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12" />
                                                    <TextBlock FontSize="11">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:g}">
                                                                <Binding Path="DateTime" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Body}"
                                                           TextWrapping="Wrap" FontSize="13" Margin="0,2,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                <TextBox PlaceholderText="Type a message..." />
                                <Button Grid.Column="1" Content="Send" Margin="8,0,0,0" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Calls Tab -->
            <TabItem Header="📞 Calls">
                <Grid Margin="8" RowDefinitions="Auto,*">
                    <Button Content="🔄 Refresh"
                            Command="{Binding CallLogViewModel.LoadCallLogCommand}"
                            HorizontalAlignment="Left" Margin="0,0,0,8" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding CallLogViewModel.Calls}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:CallLogEntry">
                                <Border Padding="8,6" Margin="0,1"
                                        BorderBrush="{DynamicResource SystemControlForegroundChromeDisabledBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0" Text="📞" FontSize="16"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="13" />
                                            <TextBlock Text="{Binding Number}" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Type}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="8,0" />
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:g}">
                                                        <Binding Path="DateTime" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DurationFormatted}" FontSize="11"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="⚙ Settings">
                <ScrollViewer Margin="16">
                    <StackPanel Spacing="12" MaxWidth="500">
                        <TextBlock Text="Settings &amp; Pairing" FontSize="20" FontWeight="Bold" />

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Server Status" FontWeight="Bold" FontSize="14" />
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Running: {0}">
                                            <Binding Path="IsServerRunning" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Phone Connected: {0}">
                                            <Binding Path="IsConnected" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Device Pairing" FontWeight="Bold" FontSize="14" />
                                <Button Command="{Binding PairingViewModel.GeneratePairTokenCommand}"
                                        Content="Generate Pairing Token"
                                        IsEnabled="{Binding IsServerRunning}" />
                                <TextBlock Text="{Binding PairingViewModel.PairingToken}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding PairingViewModel.Fingerprint}"
                                           FontSize="11" FontFamily="Courier New" />
                                <Button Command="{Binding PairingViewModel.UnpairCommand}"
                                        Content="Unpair Device"
                                        IsEnabled="{Binding PairingViewModel.IsPaired}" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="External Access" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="{Binding ExternalIp}" />
                                <TextBlock Text="For off-LAN access, forward ports 8765-8766 to this machine."
                                           FontSize="11" />
                                <Button Command="{Binding RefreshExternalIpCommand}" Content="Refresh IP" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
