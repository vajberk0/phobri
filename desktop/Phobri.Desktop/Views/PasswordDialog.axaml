<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Phobri.Desktop.Views.PasswordDialog"
        Title="Password"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Padding="24">
        <StackPanel Spacing="16">
            <!-- Title -->
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"
                       Text="Set Up Phobri Password" />

            <!-- Description -->
            <TextBlock x:Name="DescriptionText" FontSize="12" Opacity="0.7"
                       Text="Create a password to protect your messages, call logs, and pairing data. This password is never sent over the network." />

            <!-- Password Field -->
            <StackPanel Spacing="4">
                <TextBlock Text="Password" FontSize="12" FontWeight="Medium" />
                <TextBox x:Name="PasswordBox" PasswordChar="●"
                         PlaceholderText="Enter password" />
            </StackPanel>

            <!-- Confirm Password (setup mode only) -->
            <StackPanel x:Name="ConfirmPanel" Spacing="4" IsVisible="True">
                <TextBlock Text="Confirm Password" FontSize="12" FontWeight="Medium" />
                <TextBox x:Name="ConfirmPasswordBox" PasswordChar="●"
                         PlaceholderText="Re-enter password" />
            </StackPanel>

            <!-- Error Message -->
            <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12"
                       TextWrapping="Wrap" IsVisible="False" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="CancelButton" Content="Cancel" IsVisible="False"
                        Click="OnCancelClick" />
                <Button x:Name="ActionButton" Content="Set Password"
                        Click="OnActionClick" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
